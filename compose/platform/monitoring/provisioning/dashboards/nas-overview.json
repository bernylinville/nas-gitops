{
  "uid": "nas-overview",
  "title": "NAS Overview",
  "tags": ["nas", "node-exporter", "cadvisor"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "System Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "time() - node_boot_time_seconds{instance=\"nas\"}", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "dtdurations", "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 2,
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\",instance=\"nas\"}[5m])) * 100)", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 85 }] } } }
    },
    {
      "id": 3,
      "title": "Memory Usage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "(1 - node_memory_MemAvailable_bytes{instance=\"nas\"} / node_memory_MemTotal_bytes{instance=\"nas\"}) * 100", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "id": 4,
      "title": "System Disk Usage (/)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\",instance=\"nas\"} / node_filesystem_size_bytes{mountpoint=\"/\",instance=\"nas\"}) * 100", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "id": 5,
      "title": "Data Disk Usage (/data)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/data\",instance=\"nas\"} / node_filesystem_size_bytes{mountpoint=\"/data\",instance=\"nas\"}) * 100", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "id": 6,
      "title": "Running Containers",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "count(container_last_seen{instance=\"nas\",name!=\"\"})", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 10,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\",instance=\"nas\"}[5m])) * 100)", "legendFormat": "Total" },
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"user\",instance=\"nas\"}[5m])) * 100", "legendFormat": "User" },
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"system\",instance=\"nas\"}[5m])) * 100", "legendFormat": "System" },
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"iowait\",instance=\"nas\"}[5m])) * 100", "legendFormat": "I/O Wait" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
    },
    {
      "id": 11,
      "title": "Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "node_memory_MemTotal_bytes{instance=\"nas\"}", "legendFormat": "Total" },
        { "expr": "node_memory_MemTotal_bytes{instance=\"nas\"} - node_memory_MemAvailable_bytes{instance=\"nas\"}", "legendFormat": "Used" },
        { "expr": "node_memory_Cached_bytes{instance=\"nas\"}", "legendFormat": "Cached" },
        { "expr": "node_memory_Buffers_bytes{instance=\"nas\"}", "legendFormat": "Buffers" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0, "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
    },
    {
      "id": 12,
      "title": "Disk I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total{instance=\"nas\",device=~\"sd[a-z]+|md[0-9]+\"}[5m])", "legendFormat": "{{device}} read" },
        { "expr": "-rate(node_disk_written_bytes_total{instance=\"nas\",device=~\"sd[a-z]+|md[0-9]+\"}[5m])", "legendFormat": "{{device}} write" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
    },
    {
      "id": 13,
      "title": "Network Traffic (eno1)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{instance=\"nas\",device=\"eno1\"}[5m])", "legendFormat": "Receive" },
        { "expr": "-rate(node_network_transmit_bytes_total{instance=\"nas\",device=\"eno1\"}[5m])", "legendFormat": "Transmit" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
    },
    {
      "id": 14,
      "title": "Temperature",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "node_hwmon_temp_celsius{instance=\"nas\"}", "legendFormat": "{{chip}} - {{sensor}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "celsius", "custom": { "fillOpacity": 5, "lineWidth": 2 }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 80 }] } } }
    },
    {
      "id": 15,
      "title": "System Load",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "node_load1{instance=\"nas\"}", "legendFormat": "1m" },
        { "expr": "node_load5{instance=\"nas\"}", "legendFormat": "5m" },
        { "expr": "node_load15{instance=\"nas\"}", "legendFormat": "15m" },
        { "expr": "count(node_cpu_seconds_total{mode=\"idle\",instance=\"nas\"})", "legendFormat": "CPU Cores" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10, "lineWidth": 2 } } }
    },
    {
      "id": 20,
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(container_cpu_usage_seconds_total{instance=\"nas\",name!=\"\",name!~\".*POD.*\"}[5m]) * 100", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
    },
    {
      "id": 21,
      "title": "Container Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "container_memory_usage_bytes{instance=\"nas\",name!=\"\",name!~\".*POD.*\"}", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0, "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
    },
    {
      "id": 22,
      "title": "Container Network I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(container_network_receive_bytes_total{instance=\"nas\",name!=\"\",name!~\".*POD.*\"}[5m])", "legendFormat": "{{name}} rx" },
        { "expr": "-rate(container_network_transmit_bytes_total{instance=\"nas\",name!=\"\",name!~\".*POD.*\"}[5m])", "legendFormat": "{{name}} tx" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
    },
    {
      "id": 23,
      "title": "Container Disk I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(container_fs_reads_bytes_total{instance=\"nas\",name!=\"\",name!~\".*POD.*\"}[5m])", "legendFormat": "{{name}} read" },
        { "expr": "-rate(container_fs_writes_bytes_total{instance=\"nas\",name!=\"\",name!~\".*POD.*\"}[5m])", "legendFormat": "{{name}} write" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 15, "lineWidth": 2 } } }
    }
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true
}
