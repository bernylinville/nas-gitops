---
# .ansible-lint — ansible-lint configuration for nas-gitops
exclude_paths:
  - .venv/
  - .github/
  - claude-ansible-skills-main/

skip_list:
  - galaxy  # Non-collection project — this repo is not an Ansible Galaxy collection

warn_list:
  - experimental
  - command-instead-of-module  # molecule pre_tasks legitimately use systemctl is-system-running

enable_list:
  - fqcn
  - yaml
  - name
