---
# .ansible-lint — ansible-lint configuration for nas-gitops
exclude_paths:
  - .venv/
  - .github/
  - claude-ansible-skills-main/
  - ansible/roles/geerlingguy.docker/

skip_list:
  - galaxy  # Non-collection project
  - name[casing]  # Our convention: "prefix | Action" where prefix is lowercase file name
  - ignore-errors  # Used in verify.yml for non-critical checks

warn_list:
  - experimental

enable_list:
  - fqcn
  - yaml
  - name
